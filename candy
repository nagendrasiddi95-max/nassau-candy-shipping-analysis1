   ],
   "source": [
    "%%writefile app.py\n",
    "\n",
    "import streamlit as st\n",
    "import pandas as pd\n",
    "import plotly.express as px\n",
    "\n",
    "st.set_page_config(page_title=\"Nassau Candy Shipping Dashboard\", layout=\"wide\")\n",
    "\n",
    "st.title(\"Factory-to-Customer Shipping Route Efficiency Analysis\")\n",
    "\n",
    "df = pd.read_csv(\"nassau_cleaned_features.csv\")\n",
    "\n",
    "st.sidebar.header(\"Filters\")\n",
    "\n",
    "region_filter = st.sidebar.multiselect(\n",
    "    \"Select Region\",\n",
    "    options=sorted(df[\"Region\"].dropna().unique()),\n",
    "    default=sorted(df[\"Region\"].dropna().unique())\n",
    ")\n",
    "\n",
    "state_filter = st.sidebar.multiselect(\n",
    "    \"Select State\",\n",
    "    options=sorted(df[\"State/Province\"].dropna().unique()),\n",
    "    default=sorted(df[\"State/Province\"].dropna().unique())\n",
    ")\n",
    "\n",
    "ship_filter = st.sidebar.multiselect(\n",
    "    \"Select Ship Mode\",\n",
    "    options=sorted(df[\"Ship Mode\"].dropna().unique()),\n",
    "    default=sorted(df[\"Ship Mode\"].dropna().unique())\n",
    ")\n",
    "\n",
    "filtered_df = df[\n",
    "    (df[\"Region\"].isin(region_filter)) &\n",
    "    (df[\"State/Province\"].isin(state_filter)) &\n",
    "    (df[\"Ship Mode\"].isin(ship_filter))\n",
    "]\n",
    "\n",
    "col1, col2, col3, col4 = st.columns(4)\n",
    "\n",
    "col1.metric(\"Total Shipments\", filtered_df[\"Order ID\"].count())\n",
    "col2.metric(\"Average Lead Time\", round(filtered_df[\"Shipping Lead Time\"].mean(), 2))\n",
    "col3.metric(\"Total Sales\", round(filtered_df[\"Sales\"].sum(), 2))\n",
    "col4.metric(\"Total Profit\", round(filtered_df[\"Gross Profit\"].sum(), 2))\n",
    "\n",
    "st.subheader(\"Average Lead Time by Region\")\n",
    "\n",
    "region_chart = filtered_df.groupby(\"Region\")[\"Shipping Lead Time\"].mean().reset_index()\n",
    "\n",
    "fig1 = px.bar(\n",
    "    region_chart,\n",
    "    x=\"Region\",\n",
    "    y=\"Shipping Lead Time\",\n",
    "    title=\"Average Lead Time by Region\"\n",
    ")\n",
    "\n",
    "st.plotly_chart(fig1, use_container_width=True)\n",
    "\n",
    "st.subheader(\"Average Lead Time by Ship Mode\")\n",
    "\n",
    "ship_chart = filtered_df.groupby(\"Ship Mode\")[\"Shipping Lead Time\"].mean().reset_index()\n",
    "\n",
