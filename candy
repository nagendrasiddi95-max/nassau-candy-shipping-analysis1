    "factory_summary = df.groupby(\"Factory\").agg(\n",
    "    Total_Shipments=(\"Order ID\", \"count\"),\n",
    "    Avg_Lead_Time=(\"Shipping Lead Time\", \"mean\"),\n",
    "    Delay_Count=(\"Delay_Flag\", \"sum\"),\n",
    "    Total_Sales=(\"Sales\", \"sum\"),\n",
    "    Total_Units=(\"Units\", \"sum\"),\n",
    "    Total_Cost=(\"Cost\", \"sum\"),\n",
    "    Total_Profit=(\"Gross Profit\", \"sum\")\n",
    ").reset_index()\n",
    "\n",
    "factory_summary[\"Delay_Percentage\"] = (\n",
    "    factory_summary[\"Delay_Count\"] / factory_summary[\"Total_Shipments\"] * 100\n",
    ")\n",
    "\n",
    "factory_summary = factory_summary.round(2)\n",
    "\n",
    "factory_summary"
   ]
  },
